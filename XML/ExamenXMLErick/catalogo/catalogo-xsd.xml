<?xml version="1.0" encoding="UTF-8"?>
<!-- 
EJERCICIO 3 (2 PUNTOS)

Crea catalogo.xsd para que se valide el siguiente XML y cumpla con las restricciones indicadas a continuación.

RESTRICCIONES PARA EL XSD:
- Raíz: catalogo con atributo tienda obligatorio
- De 1 a 10 elementos categoria
- Cada categoria tiene:
    - Atributo nombre obligatorio
    - De 1 a 50 producto
- Cada producto tiene:
    - Atributos: codigo (obligatorio), stock (opcional)
    - codigo debe tener un patrón: P seguido de 3 dígitos.
    - stock debe ser un entero entre 0 y 1000.
    - Elementos en orden: nombre (obligatorio), descripcion (opcional), precio (obligatorio), especificaciones (opcional)
    - precio tiene atributo moneda obligatorio (posibles valores: EUR, USD, GBP).
    - especificaciones contiene 0-n espec con atributo nombre obligatorio

NOTAS: Tienes que hacer al menos 3 tipos con nombre aplicados a elementos o atributos.
-->
<catalogo xmlns="http://erick.es/cat"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://erick.es/cat catalogo.xsd"
        tienda="TechStore">
    <categoria nombre="Electrónica">
        <producto codigo="P001" stock="25">
            <nombre>Portátil Pro</nombre>
            <descripcion>16GB RAM, 512GB SSD</descripcion>
            <precio moneda="EUR">899.99</precio>
            <especificaciones>
                <espec nombre="procesador">Intel i7</espec>
                <espec nombre="ram">16GB</espec>
            </especificaciones>
        </producto>
        <producto codigo="P002" stock="10">
            <nombre>Tablet Lite</nombre>
            <precio moneda="EUR">249.50</precio>
        </producto>
    </categoria>
    <categoria nombre="Libros">
        <producto codigo="P003" stock="3">
            <nombre>XML Avanzado</nombre>
            <precio moneda="USD">45.99</precio>
        </producto>
    </categoria>
</catalogo>